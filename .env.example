# Stripe — used by /pricing to take real test-mode payments.
# Create keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe Price IDs — create products in the Stripe dashboard and paste the Price IDs here.
STRIPE_PRICE_ONETIME=price_...
STRIPE_PRICE_SUBSCRIPTION=price_...

# Optional — override the redirect base URL for Checkout success/cancel links.
# Defaults to http://localhost:4000 in dev.
NEXT_PUBLIC_BASE_URL=http://localhost:4000
